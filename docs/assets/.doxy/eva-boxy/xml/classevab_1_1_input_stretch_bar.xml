<para>Pictoset class providing pictogram data </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>OrientationPictoPolicy</parametername>
</parameternamelist>
<parameterdescription>
<para>Policy for orientation (vertical/horizontal) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
    </detaileddescription>
