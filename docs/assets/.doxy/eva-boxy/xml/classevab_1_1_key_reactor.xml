    <briefdescription>
<para>Decorator that triggers events when values change via increment/decrement. </para>
    </briefdescription>
    <detaileddescription>
<para>Similar to <ref refid="classevab_1_1_key_modifier" kindref="compound">KeyModifier</ref> but additionally sends event notifications when the value changes through increment/decrement operations.</para>
<para><parameterlist kind="templateparam"><parameteritem>
<parameternamelist>
<parametername>T</parametername>
</parameternamelist>
<parameterdescription>
<para>Base element type (must have Increment(signed char) and GetValue() methods) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kDec</parametername>
</parameternamelist>
<parameterdescription>
<para>Key code for decrement </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kInc</parametername>
</parameternamelist>
<parameterdescription>
<para>Key code for increment </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
    </detaileddescription>
